---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';

const projects = [
  {
    title: 'YoNote',
    description: 'YoNote是一个高信息密度内容可视化 Agent',
    link: 'https://yonote.net/'
  },
  {
    title: 'Agent101',
    description: 'Agent 101网站分享唯庸写的一些智能体教程和智能体社群内容',
    link: 'https://agent101.cn/'
  },
]
---

<BaseLayout title="我的项目 | 唯庸" description="我开发或维护的项目">
  <div class="wrapper">
    <PageHeader title="项目" description="我开发或维护的项目" />
    <section class="projects">
      {projects.map(project => (
        <a
          class="project-card"
          href={project.link}
          target="_blank"
          rel="noopener noreferrer"
        >
          <h2 class="project-title">{project.title}</h2>
          <p class="project-desc">{project.description}</p>
        </a>
      ))}
    </section>
  </div>
</BaseLayout>

<style>
  .projects {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  .project-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.5rem;
    background: var(--background);
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    text-decoration: none;
    box-shadow: var(--shadow-sm);
    transition: all 0.3s ease-in-out;
  }

  .project-card:hover {
    transform: scale(1.05);
  }

  .project-title {
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--foreground);
    margin: 0;
  }

  .project-desc {
    font-size: var(--text-sm);
    color: var(--muted-foreground);
    line-height: 1.5;
    margin: 0;
    flex: 1;
  }

  @media (min-width: 640px) {
    .projects {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .projects {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
